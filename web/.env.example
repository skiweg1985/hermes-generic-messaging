# Hermes WebSocket target (host, host:port, or ws:// URL). Replaces CUSTOM_CHAT_WS_URL.
CUSTOM_CHAT_TARGET=127.0.0.1
CUSTOM_CHAT_BEARER_TOKEN=YOUR_TOKEN_HERE
WEB_CHAT_ID=workspace:demo
WEB_USER_ID=user-demo
WEB_MEDIA_UPLOAD_DIR=./data/uploads
WEB_SESSION_STORE_PATH=./data/chat_sessions.json
WEB_MAX_UPLOAD_BYTES=20971520
# Legacy alias, used only if WEB_MAX_UPLOAD_BYTES is unset:
# WEB_MAX_AUDIO_BYTES=10485760
# Optional overrides (auto-detected when unset; required for Docker/reverse proxy):
# WEB_PUBLIC_MEDIA_BASE_URL=http://127.0.0.1:8000
# WEB_CUSTOM_CHAT_MEDIA_BASE_URL=http://host.docker.internal:8000
# WEB_PUBLIC_HOST=
# WEB_PUBLIC_PORT=8000
# WEB_CORS_REFLECT_ORIGIN=true
WEB_CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
